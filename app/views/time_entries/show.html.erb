<div class="page-header">
  <div class="page-header__body">
    <h1 class="page-title"><%= @time_entry.project.name %></h1>
    <p class="page-intro">
      <%= @time_entry.project.client.name %> •
      <%= @time_entry.date.strftime("%B %d, %Y") %>
    </p>
  </div>
  <div class="action-buttons">
    <%= link_to "Edit", edit_time_entry_path(@time_entry), class: "btn secondary" %>
    <%= button_to "Delete", time_entry_path(@time_entry), method: :delete, class: "btn danger", form: { data: { turbo_confirm: "Are you sure you want to delete this time entry?" } } %>
  </div>
</div>

<div class="card">
  <p><strong>Hours:</strong> <%= format_hours_as_clock(@time_entry.hours) %></p>
  <p><strong>User:</strong> <%= @time_entry.user.full_name %></p>
  <p><strong>Status:</strong> <%= @time_entry.billed? ? "Billed" : (@time_entry.billable? ? "Billable" : "Non-billable") %></p>
  <% if @time_entry.description.present? %>
    <p><strong>Description:</strong></p>
    <p><%= @time_entry.description %></p>
  <% end %>
</div>

<div class="back-link-row">
  <%= link_to "← Back to Time Entries", time_entries_path %>
</div>
