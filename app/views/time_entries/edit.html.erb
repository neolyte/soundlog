<h1>Edit Time Entry</h1>

<div class="form-shell">
  <form method="post" action="<%= time_entry_path(@time_entry) %>">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
    <input type="hidden" name="_method" value="patch">

    <% if @time_entry.errors.any? %>
      <div class="error_explanation">
        <h2><%= pluralize(@time_entry.errors.count, "error") %> prohibited this entry from being saved:</h2>
        <ul>
          <% @time_entry.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <label for="time_entry_project_id">Project</label>
      <select id="time_entry_project_id" name="time_entry[project_id]" required>
        <option value="">Select a project...</option>
        <% @projects.each do |project| %>
          <option value="<%= project.id %>" <%= "selected" if @time_entry.project_id == project.id %>>
            <%= project.name %> (<%= project.client.name %>)
          </option>
        <% end %>
      </select>
    </div>

    <div class="form-group">
      <label for="time_entry_date">Date</label>
      <input type="date" id="time_entry_date" name="time_entry[date]" value="<%= @time_entry.date.to_s %>" required>
    </div>

    <div class="form-group">
      <label for="time_entry_hours">Hours</label>
      <input type="text" id="time_entry_hours" name="time_entry[hours]" value="<%= @time_entry.hours_before_type_cast.presence || (@time_entry.hours.present? ? format_hours_as_clock(@time_entry.hours) : @time_entry.hours) %>" placeholder="HH:MM or 1.25" data-time-entry-hours-input required>
    </div>

    <div class="form-group">
      <label for="time_entry_description">Description (optional)</label>
      <textarea id="time_entry_description" name="time_entry[description]"><%= @time_entry.description %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn">Update Time Entry</button>
      <a href="<%= time_entry_path(@time_entry) %>" class="btn secondary">Cancel</a>
    </div>
  </form>
</div>
