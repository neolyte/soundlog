<div class="page-header">
  <div class="page-header__body">
    <h1 class="page-title">Users</h1>
  </div>
  <%= link_to "+ New User", new_user_path, class: "btn" %>
</div>

<% if @users.any? %>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="clickable-row" data-row-link="<%= edit_user_path(user) %>" tabindex="0">
            <td><strong><%= user.full_name %></strong></td>
            <td><%= user.email %></td>
            <td><%= user.admin? ? "Admin" : "Member" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card">
    <p>No users yet. <%= link_to "Create one", new_user_path %></p>
  </div>
<% end %>
