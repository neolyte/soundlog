<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <div>
    <h1><%= @project.name %></h1>
    <p style="color: #6b7280; margin-bottom: 0;">
      <%= link_to @project.client.name, client_path(@project.client), style: "color: #1f2937;" %> • 
      Owner: <%= @project.user.full_name %>
    </p>
  </div>
  <div class="action-buttons">
    <%= link_to "Edit", edit_project_path(@project), class: "btn secondary" %>
    <%= button_to "Delete", project_path(@project), method: :delete, class: "btn danger", form: { data: { turbo_confirm: "Are you sure you want to delete this project?" } } %>
  </div>
</div>

<% if @project.description.present? %>
  <div class="card">
    <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Description</h3>
    <p><%= @project.description %></p>
  </div>
<% end %>

<div class="card">
  <p><strong>Hours Logged:</strong> <%= @project.total_hours_logged %> hrs</p>
  <% if @project.total_hours.present? %>
    <p><strong>Total Hours Sold:</strong> <%= @project.total_hours %> hrs</p>
    <p><strong>Hours Remaining:</strong> <%= @project.remaining_hours %> hrs</p>
  <% end %>
</div>

<h2>Time Entries</h2>
<% if @project.time_entries.any? %>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>User</th>
        <th>Hours</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <% @project.time_entries.ordered.each do |entry| %>
        <tr>
          <td><%= entry.date.strftime("%Y-%m-%d") %></td>
          <td><%= entry.user.full_name %></td>
          <td><strong><%= format_hours_as_clock(entry.hours) %></strong></td>
          <td><%= entry.description %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No time entries for this project.</p>
<% end %>

<div style="margin-top: 2rem;">
  <%= link_to "← Back to #{@project.client.name}", client_path(@project.client) %>
</div>
