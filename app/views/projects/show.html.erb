<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <div>
    <h1><%= @project.name %></h1>
    <p style="color: #6b7280; margin-bottom: 0;">
      <%= link_to @project.client.name, client_path(@project.client), style: "color: #1f2937;" %> • 
      Owner: <%= @project.user.full_name %>
    </p>
    <% if @project.archived? %>
      <p style="color: #92400e; margin: 0.35rem 0 0;">Archived project</p>
    <% end %>
  </div>
  <div class="action-buttons">
    <%= button_to(@project.active? ? "Archive" : "Unarchive",
                  project_path(@project, project_navigation_params),
                  method: :patch,
                  params: { source: params[:source], project: { active: @project.archived? } },
                  class: "btn secondary") %>
    <%= link_to "Edit", edit_project_path(@project, project_navigation_params), class: "btn secondary" %>
    <%= button_to "Delete", project_path(@project), method: :delete, class: "btn danger", form: { data: { turbo_confirm: "Are you sure you want to delete this project?" } } %>
  </div>
</div>

<% if @project.description.present? %>
  <div class="card">
    <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Description</h3>
    <p><%= @project.description %></p>
  </div>
<% end %>

<div class="card">
  <p><strong>Hours Logged:</strong> <%= format_hours_as_clock(@project.total_hours_logged) %></p>
  <% if @project.total_hours.present? %>
    <p><strong>Total Hours Sold:</strong> <%= format_hours_as_clock(@project.total_hours) %></p>
    <p><strong>Hours Remaining:</strong> <%= format_hours_as_clock(@project.remaining_hours) %></p>
  <% end %>
</div>

<div class="time-entries-page__header">
  <h2 class="time-entries-page__title">Time Entries</h2>
  <button type="button" class="btn" data-time-entry-create-toggle aria-expanded="<%= @show_log_time_form %>">+ Log Time</button>
</div>

<div class="card time-entry-create-card" data-time-entry-create-panel <%= "hidden" unless @show_log_time_form %>>
  <%= form_with model: @time_entry, url: time_entries_path, local: true, html: { data: { time_entry_create_form: true, has_errors: false } } do |form| %>
    <%= hidden_field_tag :return_to_project_id, @project.id %>
    <%= hidden_field_tag :source, params[:source] if params[:source].present? %>
    <%= hidden_field_tag :show_log_time, 1 %>
    <%= form.hidden_field :project_id, value: @project.id %>

    <div class="time-entry-editor-grid time-entry-editor-grid--create">
      <div>
        <%= form.label :date, "Date" %>
        <%= form.date_field :date, required: true, data: { time_entry_create_field: true } %>
      </div>
      <div>
        <%= form.label :hours, "Hours" %>
        <%= form.text_field :hours,
                            value: (@time_entry.hours_before_type_cast.presence || (@time_entry.hours.present? ? format_hours_as_clock(@time_entry.hours) : @time_entry.hours)),
                            required: true,
                            placeholder: "HH:MM or 1.25",
                            data: { time_entry_create_field: true, time_entry_create_focus: true, time_entry_hours_input: true } %>
      </div>
      <div class="time-entry-editor-grid__full">
        <%= form.label :description, "Description" %>
        <%= form.text_area :description,
                           rows: 4,
                           class: "time-entry-editor__textarea",
                           placeholder: "What did you work on?",
                           data: { time_entry_create_field: true } %>
      </div>
    </div>
    <div class="time-entry-editor-actions">
      <%= form.submit "Log Time", class: "btn secondary" %>
      <button type="button" class="btn" data-time-entry-create-cancel>Cancel</button>
    </div>
  <% end %>
</div>
<% if @time_entries.any? %>
  <div class="card time-entries-ledger project-time-entries-ledger">
    <% @time_entries.each do |entry| %>
      <% accent = project_accent_colors(@project) %>
      <div class="time-entry-ledger__item" data-time-entry-item style="--project-accent: <%= accent[:strong] %>; --project-accent-soft: <%= accent[:soft] %>;">
        <div class="time-entry-ledger__row project-time-entries-ledger__row clickable-row<%= ' is-success' if params[:highlight_time_entry_id].to_s == entry.id.to_s %>"
             data-time-entry-row
             data-time-entry-id="<%= entry.id %>"
             data-time-entry-hours-value="<%= entry.hours.to_s %>"
             data-time-entry-success-state="<%= params[:highlight_time_entry_state] if params[:highlight_time_entry_id].to_s == entry.id.to_s %>"
             tabindex="0">
          <div class="time-entry-ledger__who">
            <div class="time-entry-ledger__owner"><%= entry.user.full_name %></div>
            <div class="time-entry-ledger__date" data-time-entry-display="date"><%= entry.date.strftime("%d/%m/%Y") %></div>
          </div>
          <div class="time-entry-ledger__project">
            <div class="time-entry-ledger__project-line" data-time-entry-display="project">
              <strong><%= @project.name %></strong> <span>(<%= @project.client.name %>)</span>
            </div>
            <div class="time-entry-ledger__description" data-time-entry-display="description"><%= entry.description.presence || "No description" %></div>
          </div>
          <div class="time-entry-ledger__hours" data-time-entry-display="hours"><%= format_hours_as_clock(entry.hours) %></div>
        </div>

        <div class="time-entry-ledger__editor" data-time-entry-editor-row hidden>
          <%= form_with model: entry, url: time_entry_path(entry), method: :patch, local: true, data: { time_entry_form: true } do |form| %>
            <%= hidden_field_tag :return_to_project_id, @project.id %>
            <%= hidden_field_tag :source, params[:source] if params[:source].present? %>

            <div class="time-entry-editor-grid time-entry-editor-grid--project">
              <div>
                <%= form.label :date, "Date" %>
                <%= form.date_field :date, data: { time_entry_field: "date" } %>
              </div>
              <div>
                <%= form.label :hours, "Hours" %>
                <%= form.text_field :hours,
                                    value: format_hours_as_clock(entry.hours),
                                    placeholder: "HH:MM or 1.25",
                                    data: { time_entry_field: "hours", time_entry_hours_input: true } %>
              </div>
              <div class="time-entry-editor-grid__full">
                <%= form.label :description, "Description" %>
                <%= form.text_area :description,
                                   rows: 4,
                                   class: "time-entry-editor__textarea",
                                   data: { time_entry_field: "description" },
                                   placeholder: "What did you work on?" %>
              </div>
            </div>
            <div class="time-entry-editor-actions">
              <div class="time-entry-editor-actions__group">
                <%= form.submit "Save", class: "btn secondary small" %>
                <button type="button" class="btn small" data-time-entry-cancel>Cancel</button>
              </div>
              <button type="button" class="btn danger small" data-time-entry-delete data-time-entry-delete-url="<%= time_entry_path(entry) %>">Delete</button>
            </div>
          <% end %>
        </div>

        <div class="time-entry-feedback-cell" data-time-entry-feedback-row data-time-entry-feedback hidden></div>
      </div>
    <% end %>

    <div class="time-entries-ledger__footer">
      <div></div>
      <div class="time-entries-ledger__footer-label"></div>
      <div class="time-entries-ledger__footer-hours">Total: <%= format_hours_as_clock(@page_total) %></div>
    </div>
  </div>
<% else %>
  <div class="card">
    <p>No time entries for this project. <button type="button" class="btn-link" data-time-entry-create-toggle>Log some time</button></p>
  </div>
<% end %>

<div style="margin-top: 2rem;">
  <% if project_navigation_from_projects? %>
    <%= link_to "← Back to Projects", projects_path %>
  <% else %>
    <%= link_to "← Back to #{@project.client.name}", client_path(@project.client) %>
  <% end %>
</div>
