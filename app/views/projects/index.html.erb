<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <div>
    <h1 style="margin-bottom: 0.25rem;"><%= @client ? "#{@client.name} Projects" : "All Projects" %></h1>
    <% if @client %>
      <p style="color: #6b7280; margin: 0;">Projects scoped to <%= @client.name %>.</p>
    <% end %>
  </div>
  <% if @client %>
    <%= link_to "+ New Project", new_client_project_path(@client), class: "btn" %>
  <% end %>
</div>

<% if @projects.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <% unless @client %>
          <th>Client</th>
        <% end %>
        <th>Owner</th>
        <th>Hours Budget</th>
        <th style="width: 150px;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr>
          <td><strong><%= link_to project.name, project_path(project), style: "color: #1f2937; text-decoration: none;" %></strong></td>
          <% unless @client %>
            <td><%= link_to project.client.name, client_path(project.client), style: "color: #1f2937; text-decoration: none;" %></td>
          <% end %>
          <td><%= project.user.email %></td>
          <td>
            <% if project.total_hours.present? %>
              <strong><%= project.total_hours %></strong> hrs
              <span style="color: #6b7280;">(<%= project.remaining_hours %> remaining)</span>
            <% else %>
              <span style="color: #6b7280;">Not set</span>
            <% end %>
          </td>
          <td>
            <div class="action-buttons">
              <%= link_to "Edit", edit_project_path(project), class: "btn secondary small" %>
              <%= button_to "Delete", project_path(project), method: :delete, class: "btn danger small", form: { data: { turbo_confirm: "Are you sure you want to delete this project?" } } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="card">
    <% if @client %>
      <p>No projects yet. <%= link_to "Create one", new_client_project_path(@client) %></p>
    <% else %>
      <p>No projects yet.</p>
    <% end %>
  </div>
<% end %>
