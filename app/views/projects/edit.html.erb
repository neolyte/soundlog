<h1>Edit Project</h1>

<div style="max-width: 500px;">
  <form method="post" action="<%= project_path(@project) %>">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
    <input type="hidden" name="_method" value="patch">
    <% if project_navigation_from_projects? %>
      <input type="hidden" name="source" value="projects">
    <% end %>

    <% if @project.errors.any? %>
      <div class="error_explanation">
        <h2><%= pluralize(@project.errors.count, "error") %> prohibited this project from being saved:</h2>
        <ul>
          <% @project.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <p style="color: #6b7280; margin-bottom: 1.5rem;">Client: <strong><%= @project.client.name %></strong></p>

    <div class="form-group">
      <label for="project_name">Project Name</label>
      <input type="text" id="project_name" name="project[name]" value="<%= @project.name %>" required>
    </div>

    <div class="form-group">
      <label for="project_description">Description (optional)</label>
      <textarea id="project_description" name="project[description]"><%= @project.description %></textarea>
    </div>

    <div class="form-group">
      <label for="project_total_hours">Total Hours Sold (optional)</label>
      <input type="number" id="project_total_hours" name="project[total_hours]" value="<%= @project.total_hours %>" min="0" step="0.25">
    </div>

    <div class="form-group">
      <label for="project_active">
        <input type="hidden" name="project[active]" value="0">
        <input type="checkbox" id="project_active" name="project[active]" value="1" <%= "checked" if @project.active? %>>
        Active project
      </label>
      <p style="color: #6b7280; margin-top: 0.35rem;">Archived projects are hidden from project lists and project pickers.</p>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn">Update Project</button>
      <a href="<%= project_path(@project) %>" class="btn secondary">Cancel</a>
    </div>
  </form>
</div>
