<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <h1><%= @client.name %></h1>
  <div class="action-buttons">
    <%= link_to "+ New Project", new_client_project_path(@client), class: "btn" %>
    <%= link_to "Edit", edit_client_path(@client), class: "btn secondary" %>
    <%= button_to "Delete", client_path(@client), method: :delete, class: "btn danger", form: { data: { turbo_confirm: "Are you sure you want to delete this client?" } } %>
  </div>
</div>

<h2>Projects</h2>
<% if @projects.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Hours Logged</th>
        <th>Hours Budget</th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr class="clickable-row" data-row-link="<%= project_path(project) %>" tabindex="0">
          <td><strong><%= project.name %></strong></td>
          <td><%= project.total_hours_logged %> hrs</td>
          <td>
            <% if project.total_hours.present? %>
              <strong><%= project.total_hours %></strong> hrs
              <span style="color: #6b7280;">(<%= project.remaining_hours %> remaining)</span>
            <% else %>
              <span style="color: #6b7280;">Not set</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No projects for this client. <%= link_to "Create one", new_client_project_path(@client) %></p>
<% end %>

<div style="margin-top: 2rem;">
  <%= link_to "← Back to Clients", clients_path %>
</div>
