<div class="time-entries-page__header">
  <div>
    <h1 class="time-entries-page__title"><%= @client.name %></h1>
    <p style="color: #6b7280; margin: 0;">Client overview and active project ledger.</p>
  </div>
  <div class="action-buttons">
    <%= link_to "+ New Project", new_client_project_path(@client), class: "btn" %>
    <%= link_to "Edit", edit_client_path(@client), class: "btn secondary" %>
    <%= button_to "Delete", client_path(@client), method: :delete, class: "btn danger", form: { data: { turbo_confirm: "Are you sure you want to delete this client?" } } %>
  </div>
</div>

<div class="card time-entries-toolbar">
  <div class="time-entries-toolbar__meta">
    <div class="time-entries-toolbar__period">
      <p><strong><%= @projects_count %></strong> active projects</p>
      <p>Logged: <strong><%= format_hours_as_clock(@logged_total) %></strong></p>
      <% if @budget_total.positive? %>
        <p>Budget: <strong><%= format_hours_as_clock(@budget_total) %></strong> • Remaining: <strong><%= format_hours_as_clock(@remaining_total) %></strong></p>
      <% end %>
    </div>
  </div>
</div>

<h2>Projects</h2>
<% if @projects.any? %>
  <div class="card time-entries-ledger projects-ledger">
    <% @projects.each do |project| %>
      <% accent = project_accent_colors(project) %>
      <div class="time-entry-ledger__item" style="--project-accent: <%= accent[:strong] %>; --project-accent-soft: <%= accent[:soft] %>;">
        <div class="time-entry-ledger__row projects-ledger__row clickable-row" data-row-link="<%= project_path(project) %>" tabindex="0">
          <div class="time-entry-ledger__project projects-ledger__project">
            <div class="time-entry-ledger__project-line">
              <strong><%= project.name %></strong>
            </div>
            <div class="time-entry-ledger__description"><%= @client.name %></div>
          </div>
          <div class="time-entry-ledger__hours projects-ledger__hours">
            <% if project.total_hours.present? %>
              <% progress_percent = [(project.total_hours_logged.to_f / project.total_hours.to_f) * 100, 100].min %>
              <div class="projects-ledger__hours-primary">
                <%= project.total_hours_logged.to_f.round %>
                <span>of <%= project.total_hours.to_f.round %> hours</span>
              </div>
              <div class="projects-ledger__progress" aria-hidden="true">
                <div class="projects-ledger__progress-bar" style="width: <%= progress_percent.round(1) %>%"></div>
              </div>
            <% else %>
              <div class="projects-ledger__hours-primary"><%= project.total_hours_logged.to_f.round %> hours</div>
            <% end %>
          </div>
          <div class="time-entry-ledger__who projects-ledger__who">
            <div class="projects-ledger__entry-label">Last entry</div>
            <% latest_entry = project.latest_time_entry %>
            <div class="time-entry-ledger__owner"><%= latest_entry&.user&.full_name || "No entries yet" %></div>
            <div class="time-entry-ledger__date"><%= latest_entry.present? ? latest_entry.date.strftime('%d/%m/%Y') : "No activity yet" %></div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="time-entries-ledger__footer projects-ledger__footer">
      <div class="projects-ledger__footer-count">
        <strong><%= pluralize(@projects_count, "project") %></strong>
      </div>
      <div class="time-entries-ledger__footer-label">
        <% if @budget_total.positive? %>
          Budget: <strong><%= format_hours_as_clock(@budget_total) %></strong> • Remaining: <strong><%= format_hours_as_clock(@remaining_total) %></strong>
        <% else %>
          No budget totals on these projects
        <% end %>
      </div>
      <div class="time-entries-ledger__footer-hours">Logged: <%= format_hours_as_clock(@logged_total) %></div>
    </div>
  </div>
<% else %>
  <div class="card">
    <p>No projects for this client. <%= link_to "Create one", new_client_project_path(@client) %></p>
  </div>
<% end %>

<div style="margin-top: 2rem;">
  <%= link_to "← Back to Clients", clients_path %>
</div>
