<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <h1>Clients</h1>
  <div class="action-buttons">
    <%= link_to "All Projects", projects_path, class: "btn secondary" %>
    <a href="/clients/new" class="btn">+ New Client</a>
  </div>
</div>

<% if @clients.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Projects</th>
      </tr>
    </thead>
    <tbody>
      <% @clients.each do |client| %>
        <tr class="clickable-row" data-row-link="<%= client_path(client) %>" tabindex="0">
          <td><strong><%= client.name %></strong></td>
          <td><%= client.projects.count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="card">
    <p>No clients yet. <%= link_to "Create one", new_client_path %></p>
  </div>
<% end %>
