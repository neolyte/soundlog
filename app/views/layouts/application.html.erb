<!DOCTYPE html>
<html>
  <head>
    <title>SoundLog - Time Tracking</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if logged_in? %>
      <div class="app-shell">
        <aside class="sidebar">
          <div class="sidebar__brand">
            <a href="/" class="logo">SoundLog</a>
            <p class="sidebar__user"><%= current_user.full_name %></p>
          </div>

          <nav class="sidebar-nav">
            <%= sidebar_nav_link "Dashboard", root_path, :dashboard if admin? %>
            <%= sidebar_nav_link "Projects", projects_path, :projects %>
            <%= sidebar_nav_link "Time Entries", time_entries_path, :time_entries %>
            <%= sidebar_nav_link "Clients", clients_path, :clients %>
          </nav>

          <div class="sidebar__footer">
            <%= sidebar_nav_link "Users", users_path, :users if admin? %>
            <%= button_to logout_path, method: :delete, class: "sidebar-nav__button" do %>
              <span class="sidebar-nav__icon"><%= nav_icon(:logout) %></span>
              <span class="sidebar-nav__label">Logout</span>
            <% end %>
          </div>
        </aside>

        <main class="main-content">
          <div class="container">
            <% if notice %>
              <div class="flash notice"><%= notice %></div>
            <% end %>
            <% if alert %>
              <div class="flash alert"><%= alert %></div>
            <% end %>

            <% if breadcrumbs.size > 1 %>
              <nav class="breadcrumbs" aria-label="Breadcrumb">
                <% breadcrumbs.each_with_index do |(label, path), index| %>
                  <% if index == breadcrumbs.size - 1 %>
                    <span><%= label %></span>
                  <% else %>
                    <%= link_to label, path %>
                    <span>/</span>
                  <% end %>
                <% end %>
              </nav>
            <% end %>

            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <div class="container">
        <% if notice %>
          <div class="flash notice"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div class="flash alert"><%= alert %></div>
        <% end %>

        <%= yield %>
      </div>
    <% end %>

    <% if logged_in? %>
      <%= render "shared/timer_widget" %>
    <% end %>

    <script>
      document.addEventListener("click", function(event) {
        const row = event.target.closest("[data-row-link]");

        if (!row) return;
        if (event.target.closest("a, button, form, input, select, textarea, label")) return;

        window.location = row.dataset.rowLink;
      });

      document.addEventListener("keydown", function(event) {
        const row = event.target.closest("[data-row-link]");

        if (!row) return;
        if (event.key !== "Enter" && event.key !== " ") return;

        event.preventDefault();
        window.location = row.dataset.rowLink;
      });
    </script>
  </body>
</html>
