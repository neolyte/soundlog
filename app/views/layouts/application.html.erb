<!DOCTYPE html>
<html>
  <head>
    <title>SoundLog - Time Tracking</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= javascript_importmap_tags %>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f9fafb; color: #1f2937; line-height: 1.5; }
      header { background: white; border-bottom: 1px solid #e5e7eb; padding: 1rem 2rem; }
      header nav { display: flex; justify-content: space-between; align-items: center; max-width: 1024px; margin: 0 auto; }
      header a { text-decoration: none; color: #1f2937; }
      header .logo { font-weight: 700; font-size: 1.25rem; }
      header .nav-links { display: flex; gap: 1rem; }
      header .nav-links a { color: #4b5563; text-decoration: none; }
      header .nav-links a:hover { color: #1f2937; }
      .container { max-width: 1024px; margin: 2rem auto; padding: 0 1rem; }
      .flash { padding: 0.75rem 1rem; margin-bottom: 1rem; border-radius: 0.25rem; }
      .flash.notice { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
      .flash.alert { background: #fee2e2; color: #7f1d1d; border: 1px solid #fecaca; }
      h1 { font-size: 2rem; margin-bottom: 1.5rem; }
      h2 { font-size: 1.5rem; margin-bottom: 1rem; }
      .btn { display: inline-flex; align-items: center; justify-content: center; min-height: 2.5rem; padding: 0.5rem 1rem; background: #1f2937; color: white; text-decoration: none; border-radius: 0.25rem; cursor: pointer; border: none; font-size: 1rem; line-height: 1.2; }
      .btn:hover { background: #111827; }
      .btn.secondary { background: #6b7280; }
      .btn.secondary:hover { background: #4b5563; }
      .btn.danger { background: #dc2626; }
      .btn.danger:hover { background: #b91c1c; }
      .btn.small { min-height: 2rem; padding: 0.25rem 0.75rem; font-size: 0.875rem; }
      .button_to { display: inline-block; }
      .action-buttons { display: flex; gap: 0.5rem; align-items: center; }
      table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
      table th { background: #f3f4f6; padding: 0.75rem; text-align: left; font-weight: 600; border-bottom: 1px solid #e5e7eb; }
      table td { padding: 0.75rem; border-bottom: 1px solid #e5e7eb; }
      table tr:hover { background: #f9fafb; }
      tr.clickable-row { cursor: pointer; transition: background-color 160ms ease, color 160ms ease; }
      tr.clickable-row:hover { background: #eef2ff; }
      tr.clickable-row:focus-visible { outline: 2px solid #1f2937; outline-offset: -2px; }
      .breadcrumbs { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; color: #6b7280; font-size: 0.925rem; }
      .breadcrumbs a { color: #4b5563; text-decoration: none; }
      .breadcrumbs a:hover { color: #1f2937; }
      .form-group { margin-bottom: 1.5rem; }
      label { display: block; margin-bottom: 0.5rem; font-weight: 500; }
      input[type="text"], input[type="email"], input[type="password"], input[type="date"], input[type="number"], textarea, select { width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.25rem; font-size: 1rem; }
      input[type="text"]:focus, input[type="email"]:focus, input[type="password"]:focus, input[type="date"]:focus, input[type="number"]:focus, textarea:focus, select:focus { outline: none; border-color: #1f2937; box-shadow: 0 0 0 3px rgba(31, 41, 55, 0.1); }
      textarea { resize: vertical; min-height: 100px; }
      .form-actions { display: flex; gap: 1rem; }
      .card { background: white; border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1.5rem; }
      .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
      .stat-card { background: white; border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 1.5rem; text-align: center; }
      .stat-card .number { font-size: 2rem; font-weight: 700; color: #1f2937; }
      .stat-card .label { color: #6b7280; font-size: 0.875rem; }
      .error_explanation { background: #fee2e2; color: #7f1d1d; border: 1px solid #fecaca; border-radius: 0.25rem; padding: 1rem; margin-bottom: 1.5rem; }
      .error_explanation h2 { color: #7f1d1d; font-size: 1rem; margin-bottom: 0.5rem; }
      .error_explanation ul { list-style: none; }
      .error_explanation li { margin-bottom: 0.25rem; }
      .field_with_errors input, .field_with_errors textarea, .field_with_errors select { border-color: #dc2626; }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <div>
          <a href="/" class="logo">SoundLog</a>
        </div>
        <% if logged_in? %>
          <div class="nav-links">
            <a href="/time_entries">Time Entries</a>
            <a href="/clients">Clients</a>
            <% if admin? %>
              <span style="color: #6b7280;">| Admin</span>
            <% end %>
            <%= button_to "Logout", logout_path, method: :delete, form: { style: "display: inline-block;" }, style: "color: #6b7280; background: none; border: 0; padding: 0; font: inherit; cursor: pointer;" %>
          </div>
        <% end %>
      </nav>
    </header>

    <div class="container">
      <% if notice %>
        <div class="flash notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash alert"><%= alert %></div>
      <% end %>

      <% if logged_in? && breadcrumbs.size > 1 %>
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <% breadcrumbs.each_with_index do |(label, path), index| %>
            <% if index == breadcrumbs.size - 1 %>
              <span><%= label %></span>
            <% else %>
              <%= link_to label, path %>
              <span>/</span>
            <% end %>
          <% end %>
        </nav>
      <% end %>

      <%= yield %>
    </div>

    <script>
      document.addEventListener("click", function(event) {
        const row = event.target.closest("tr[data-row-link]");

        if (!row) return;
        if (event.target.closest("a, button, form, input, select, textarea, label")) return;

        window.location = row.dataset.rowLink;
      });

      document.addEventListener("keydown", function(event) {
        const row = event.target.closest("tr[data-row-link]");

        if (!row) return;
        if (event.key !== "Enter" && event.key !== " ") return;

        event.preventDefault();
        window.location = row.dataset.rowLink;
      });
    </script>
  </body>
</html>
